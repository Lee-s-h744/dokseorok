# MongoDB 연결 문자열
# - Atlas(클라우드): https://cloud.mongodb.com 에서 클러스터 생성 후 Connect → Drivers 의 URI 복사
#   예) mongodb+srv://<id>:<pw>@cluster0.xxxxx.mongodb.net/dokseorok?retryWrites=true&w=majority
# - 로컬 설치 시:    mongodb://localhost:27017/dokseorok
MONGODB_URI=mongodb://localhost:27017/dokseorok

# 공통
PORT=4000
JWT_SECRET=dokseorok-secret-change-me
CLIENT_ORIGIN=http://localhost:5173

# 카카오 Books API REST 키 (https://developers.kakao.com)
# 비워두면 server/src/data/seedBooks.js 의 샘플 데이터로 동작합니다.
KAKAO_REST_API_KEY=
